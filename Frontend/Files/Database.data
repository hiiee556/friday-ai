      display: inline-block;
      margin: 10px;
    }
    .balloon.red {
      background-color: #ff69b4;
    }
    .balloon.blue {
      background-color: #87ceeb;
    }
    .balloon.green {
      background-color: #32cd32;
    }
    .balloon::before {
      content: '';
      width: 2px;
      height: 20px;
      background-color: #666;
      position: absolute;
      top: 30px;
      left: 50%;
      transform: translateX(-50%);
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Happy Birthday</h1>
    </div>
    <div class="content">
      <p class="birthday-message">Enter your name to get a birthday wish!</p>
      <input type="text" id="name" class="name-input" placeholder="Name">
      <button id="wish-button" class="wish-button">Get Wish</button>
      <div id="wish-message"></div>
      <div class="cake">
        <div class="candle" style="top: -20px; left: 50%; transform: translateX(-50%);"></div>
      </div>
      <div class="balloons">
        <div class="balloon red"></div>
        <div class="balloon blue"></div>
        <div class="balloon green"></div>
      </div>
    </div>
  </div>
  <script>
    document.getElementById('wish-button').addEventListener('click', function() {
      var name = document.getElementById('name').value;
      document.getElementById('wish-message').innerHTML = 'Happy Birthday ' + name + '!';
    });
  </script>
</body>
</html>
```
